---
interface Props {
  href: string;
  title: string;
  tagline: string;
  heroImage: string;
  tech?: string[];
  status?: string;
}
const { href, title, tagline, heroImage, tech = [], status } = Astro.props;

const statusClass: Record<string, string> = {
  shipped: 'badge--green',
  'in-progress': 'badge--blue',
  prototype: 'badge--orange',
  archived: 'badge--muted',
};
---

<a class="project-card card" href={href}>
  <div class="project-card__media">
    <img src={heroImage} alt="" loading="lazy" />
  </div>
  <div class="project-card__body">
    <div class="project-card__head">
      <h3>{title}</h3>
      {status && (
        <span class={`badge ${statusClass[status] ?? 'badge--muted'}`}>
          {status.replace('-', ' ')}
        </span>
      )}
    </div>
    <p>{tagline}</p>
    {tech.length > 0 && (
      <ul class="project-card__tech">
        {tech.slice(0, 4).map((t) => <li>{t}</li>)}
      </ul>
    )}
  </div>
</a>

<style>
  .project-card {
    display: flex;
    flex-direction: column;
    padding: 0;
    overflow: hidden;
    color: inherit;
    border-bottom: 3px solid var(--c-ink);
  }
  .project-card:hover h3 { color: var(--c-orange); }
  .project-card__media {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-bottom: 3px solid var(--c-ink);
    background: var(--c-bg-alt);
  }
  .project-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    image-rendering: pixelated;
    transition: transform 300ms ease;
  }
  .project-card:hover .project-card__media img {
    transform: scale(1.04);
  }
  .project-card__body { padding: 1.25rem 1.5rem 1.5rem; }
  .project-card__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.4rem;
  }
  .project-card__head h3 { margin: 0; transition: color 140ms ease; }
  .project-card__body p {
    color: var(--c-ink-soft);
    margin: 0 0 0.9rem;
  }
  .project-card__tech {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    padding: 0;
    margin: 0;
  }
  .project-card__tech li {
    font-family: var(--font-display);
    font-size: 0.82rem;
    padding: 0.1em 0.55em;
    background: var(--c-bg-alt);
    border: 2px solid var(--c-rule);
    border-radius: 999px;
    color: var(--c-ink-soft);
  }
</style>
