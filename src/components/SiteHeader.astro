---
interface Props {
  activePath?: string;
}
const { activePath = Astro.url.pathname } = Astro.props;

const links = [
  { href: '/', label: 'Home' },
  { href: '/projects', label: 'Projects' },
  { href: '/blog', label: 'Blog' },
];

const isActive = (href: string) =>
  href === '/' ? activePath === '/' : activePath.startsWith(href);
---

<header class="site-header">
  <div class="container site-header__inner">
    <a href="/" class="site-header__brand" aria-label="Home">
      <span class="site-header__mark">▲</span>
      <span class="site-header__name">bill.dev</span>
    </a>
    <nav class="site-nav" aria-label="Main">
      <ul>
        {links.map((l) => (
          <li>
            <a href={l.href} class={isActive(l.href) ? 'is-active' : ''}>
              {l.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    background: var(--c-bg);
    border-bottom: 3px solid var(--c-ink);
    position: sticky;
    top: 0;
    z-index: 10;
    backdrop-filter: saturate(1.2);
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 1rem;
    padding-bottom: 1rem;
  }
  .site-header__brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-display);
    font-size: 1.4rem;
    color: var(--c-ink);
    border-bottom: none;
  }
  .site-header__mark {
    display: inline-block;
    width: 1.4em;
    height: 1.4em;
    line-height: 1.4em;
    text-align: center;
    background: var(--c-orange);
    color: var(--c-bg);
    border: 2px solid var(--c-ink);
    border-radius: 4px;
    transform: rotate(-6deg);
    box-shadow: 2px 2px 0 var(--c-ink);
  }
  .site-header__brand:hover .site-header__mark {
    transform: rotate(4deg);
    transition: transform 150ms ease;
  }
  .site-nav ul {
    list-style: none;
    display: flex;
    gap: 0.5rem;
    margin: 0;
    padding: 0;
  }
  .site-nav a {
    font-family: var(--font-display);
    font-size: 1.05rem;
    color: var(--c-ink);
    padding: 0.4em 0.9em;
    border: 2px solid transparent;
    border-radius: 4px;
    border-bottom: 2px solid transparent;
  }
  .site-nav a:hover,
  .site-nav a:focus-visible {
    background: var(--c-bg-alt);
    border-color: var(--c-ink);
  }
  .site-nav a.is-active {
    background: var(--c-ink);
    color: var(--c-bg);
    border-color: var(--c-ink);
  }
  @media (max-width: 560px) {
    .site-header__inner { flex-direction: column; gap: 0.75rem; }
  }
</style>
