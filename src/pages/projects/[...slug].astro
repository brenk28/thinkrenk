---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((p) => ({ params: { slug: p.id }, props: { project: p } }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const { title, tagline, tech, repo, liveUrl, heroImage, gallery, status } = project.data;

const statusClass: Record<string, string> = {
  shipped: 'badge--green',
  'in-progress': 'badge--blue',
  prototype: 'badge--orange',
  archived: 'badge--muted',
};
---

<BaseLayout title={title} description={tagline} activePath="/projects">
  <article class="project">
    <div class="container">
      <p class="project__crumb"><a href="/projects">← All projects</a></p>
      <div class="project__head">
        <div>
          <span class={`badge ${statusClass[status] ?? 'badge--muted'}`}>{status.replace('-', ' ')}</span>
          <h1>{title}</h1>
          <p class="project__tagline">{tagline}</p>
          {tech.length > 0 && (
            <ul class="project__tech">
              {tech.map((t) => <li>{t}</li>)}
            </ul>
          )}
          <div class="project__actions">
            {liveUrl && <a class="btn btn--primary" href={liveUrl} target="_blank" rel="noopener">Visit Site ↗</a>}
            {repo && <a class="btn" href={repo} target="_blank" rel="noopener">Source Code ↗</a>}
          </div>
        </div>
        <div class="project__hero">
          <img src={heroImage} alt={`${title} hero`} />
        </div>
      </div>

      <div class="project__body prose">
        <Content />
      </div>

      {gallery.length > 0 && (
        <section class="project__gallery">
          <h2>Gallery</h2>
          <div class="gallery-grid">
            {gallery.map((g) => (
              <figure>
                <img src={g.src} alt={g.alt} loading="lazy" />
                {g.alt && <figcaption>{g.alt}</figcaption>}
              </figure>
            ))}
          </div>
        </section>
      )}
    </div>
  </article>
</BaseLayout>

<style>
  .project__crumb {
    font-family: var(--font-display);
    margin-bottom: 1rem;
  }
  .project__head {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 2.5rem;
    align-items: center;
    margin-bottom: 3rem;
  }
  .project__head h1 { margin: 0.6rem 0 0.4rem; }
  .project__tagline {
    font-size: 1.2rem;
    color: var(--c-ink-soft);
    margin-bottom: 1.25rem;
  }
  .project__tech {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    padding: 0;
    margin: 0 0 1.5rem;
  }
  .project__tech li {
    font-family: var(--font-display);
    font-size: 0.9rem;
    padding: 0.15em 0.65em;
    background: var(--c-bg-alt);
    border: 2px solid var(--c-rule);
    border-radius: 999px;
    color: var(--c-ink-soft);
  }
  .project__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .project__hero img {
    border: 3px solid var(--c-ink);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    image-rendering: pixelated;
  }
  .project__body { margin: 3rem 0; }
  .project__gallery { margin-top: 3rem; }
  .project__gallery h2 {
    border-bottom: 4px solid var(--c-ink);
    padding-bottom: 0.5rem;
    margin-bottom: 1.5rem;
  }
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.5rem;
  }
  .gallery-grid figure {
    margin: 0;
    border: 3px solid var(--c-ink);
    border-radius: var(--radius);
    box-shadow: var(--shadow-sm);
    overflow: hidden;
    background: var(--c-bg-alt);
  }
  .gallery-grid img {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    image-rendering: pixelated;
  }
  .gallery-grid figcaption {
    padding: 0.5rem 0.8rem;
    font-size: 0.9rem;
    color: var(--c-ink-soft);
    border-top: 2px solid var(--c-rule);
    background: var(--c-bg);
  }
  @media (max-width: 820px) {
    .project__head { grid-template-columns: 1fr; }
    .gallery-grid { grid-template-columns: 1fr; }
  }
</style>
